# NextAuth.js
# Generate a secret with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-me-with-a-long-random-string"
NEXTAUTH_URL="http://localhost:3000"

# Database (Postgres) — provision via Vercel Postgres, Neon, Supabase, etc.
# Example: postgres://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require
DATABASE_URL="postgres://user:password@localhost:5432/ihatedocs"
