// Prisma schema for "I Hate Docs" authentication.
//
// Provider: postgresql (Vercel Postgres / Neon / Supabase / any Postgres).
// To use locally without Postgres, switch `provider` to "sqlite" and
// `DATABASE_URL` to `file:./dev.db`, then run `npx prisma db push`.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String   @id @default(cuid())
  name           String?
  email          String   @unique
  hashedPassword String
  image          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}
